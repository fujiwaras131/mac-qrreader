<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">

    <title>QR Reader</title>
    <organization>com.company</organization>
    <domains enable_localSystem="true"/>
    <options customize="never" require-scripts="true" hostArchitectures="x86_64,arm64"/>

    <welcome    file="welcome.html"    mime-type="text/html"/>

    <pkg-ref id="com.company.qrreader"/>

    <choices-outline>
        <line choice="com.company.qrreader"/>
    </choices-outline>

    <choice id="com.company.qrreader" visible="false">
        <pkg-ref id="com.company.qrreader"/>
    </choice>

    <pkg-ref id="com.company.qrreader"
             version="0.1.0"
             onConclusionAction="none">
        #qr-reader-component.pkg
    </pkg-ref>

</installer-gui-script>
